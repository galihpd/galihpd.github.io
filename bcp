        // --- HELPER FUNCTION UNTUK MEMBULATKAN SUDUT VECTOR PATH NATIVE ---
        function getRoundedPath(points, radius, isClosed) {
            if (points.length < 3 || radius <= 0) {
                let d = '';
                if(points.length > 0) d += `M ${points[0].x} ${points[0].y}`;
                for(let i=1; i<points.length; i++) d += ` L ${points[i].x} ${points[i].y}`;
                return isClosed && points.length > 2 ? d + ' Z' : d;
            }

            let d = "";
            const len = points.length;
            
            for (let i = 0; i < len; i++) {
                let p = points[i];
                let prev = isClosed ? points[(i - 1 + len) % len] : points[i - 1];
                let next = isClosed ? points[(i + 1) % len] : points[i + 1];

                if (!prev || !next) {
                    if (i === 0) d += `M ${p.x} ${p.y} `;
                    else d += `L ${p.x} ${p.y} `;
                    continue;
                }

                let dx1 = prev.x - p.x, dy1 = prev.y - p.y;
                let d1 = Math.sqrt(dx1*dx1 + dy1*dy1) || 1;
                let dx2 = next.x - p.x, dy2 = next.y - p.y;
                let d2 = Math.sqrt(dx2*dx2 + dy2*dy2) || 1;

                let r = Math.min(radius, d1/2, d2/2);

                if (r <= 0.1) {
                     if (i === 0) {
                         if (isClosed) d += `M ${p.x} ${p.y} `; 
                         else d += `M ${p.x} ${p.y} `;
                     } else {
                         d += `L ${p.x} ${p.y} `;
                     }
                     continue;
                }

                let p1x = p.x + (dx1 / d1) * r;
                let p1y = p.y + (dy1 / d1) * r;
                let p2x = p.x + (dx2 / d2) * r;
                let p2y = p.y + (dy2 / d2) * r;

                if (i === 0) {
                    if (isClosed) d += `M ${p1x} ${p1y} Q ${p.x} ${p.y} ${p2x} ${p2y} `;
                    else d += `M ${p.x} ${p.y} `;
                } else {
                    d += `L ${p1x} ${p1y} Q ${p.x} ${p.y} ${p2x} ${p2y} `;
                }
            }
            
            if (isClosed) d += ' Z';
            return d;
        }

