                if (data.fillOpacity) {
                    const rgb = hex2rgb(data.fill || '#ffffff');
                    innerEl.style.backgroundColor = `rgba(${rgb.r}, ${rgb.g}, ${rgb.b}, ${data.fillOpacity/100})`;
