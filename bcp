                innerEl.ondblclick = (e) => {
                    e.stopPropagation();
                    innerEl.contentEditable = true;
                    innerEl.focus();
                };
                innerEl.onblur = () => {
                    innerEl.contentEditable = false;
                    saveState();
                };
                innerEl.onmousedown = (e) => {
                    if(innerEl.contentEditable === 'true') e.stopPropagation();
