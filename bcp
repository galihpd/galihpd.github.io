                div.ondragleave = handleLayerDragLeave;
                div.ondrop = (e) => handleLayerDrop(e, id);
                div.ondragend = handleLayerDragEnd;

                div.innerHTML = `
                    <div class="flex items-center gap-3 flex-1 overflow-hidden" onclick="selectElement('${id}', event.shiftKey)">
                        <i class="ph ph-dots-six-vertical text-slate-400 dark:text-app-textMuted text-lg hover:text-slate-600 dark:hover:text-white transition-colors cursor-grab"></i>
                        ${thumbHTML}
                        <input type="text" 
                               value="${layerName}" 
                               onchange="updateLayerName('${id}', this.value)"
                               onclick="event.stopPropagation(); selectElement('${id}', event.shiftKey);"
                               onmousedown="event.stopPropagation();"
                               class="bg-transparent border-none focus:outline-none focus:ring-1 focus:ring-brand-500 dark:focus:ring-white/30 rounded px-1 py-0.5 text-sm font-medium tracking-wide truncate w-full text-slate-700 dark:text-app-text ${isHidden ? 'opacity-40' : ''}">
                    </div>
                    <div class="flex items-center gap-2 shrink-0">
                        <button onclick="toggleVisibility('${id}', event)" class="p-1 text-slate-400 dark:text-app-textMuted hover:text-slate-700 dark:hover:text-white transition-colors" title="Hide/Show">
                            <i class="ph ${isHidden ? 'ph-eye-slash' : 'ph-eye'} text-base"></i>
                        </button>
                        <button onclick="toggleLock('${id}', event)" class="p-1 ${isLocked ? 'text-brand-500 dark:text-white' : 'text-slate-400 dark:text-app-textMuted hover:text-slate-700 dark:hover:text-white'} transition-colors" title="Lock/Unlock">
                            <i class="ph ${isLocked ? 'ph-lock-key' : 'ph-lock-key-open'} text-base"></i>
                        </button>
                    </div>
                `;
                container.appendChild(div);

                if (type === 'frame') {
                    const frameContent = el.querySelector('.frame-content');
                    if (frameContent) {
                        const children = Array.from(frameContent.children).filter(c => c.classList.contains('element-container'));
                        children.sort((a, b) => parseInt(b.style.zIndex || 0) - parseInt(a.style.zIndex || 0));
                        children.forEach(child => renderElement(child, depth + 1));
