                    if (shapeNode && shapeNode.tagName.toLowerCase() === 'path' && shapeNode.hasAttribute('data-original-d')) {
                        const originalD = shapeNode.getAttribute('data-original-d');
                        const points = parsePathData(originalD);
                        const isClosed = originalD.includes('Z');
                        const radiusVal = parseFloat(data.radius) || 0;
                        const w = parseFloat(data.width) || 150;
                        const h = parseFloat(data.height) || 150;
                        const vbScale = Math.max(w, h) / 100 || 1;
                        const newD = getRoundedPath(points, radiusVal / vbScale, isClosed);
