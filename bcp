<!DOCTYPE html>
<html lang="id" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Moodboard Studio</title>
    
    <!-- Google Fonts: Inter & Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@500;600;700&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Phosphor Icons -->
    <script src="https://unpkg.com/@phosphor-icons/web"></script>

    <!-- PDF & Canvas Export Libraries -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

    <!-- Alwan Color Picker (Premium UI) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/alwan/dist/css/alwan.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/alwan/dist/js/alwan.min.js"></script>

    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['"Inter"', 'sans-serif'],
                        display: ['"Outfit"', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            50: '#f0f9ff',
                            100: '#e0f2fe',
                            500: '#0ea5e9',
                            600: '#0284c7',
                        },
                        // Custom palette matching the 3D software aesthetic
                        app: {
                            bg: '#0e0e0e',          
                            panel: '#161616',       
                            surface: '#1c1c1c',     
                            surfaceHover: '#2a2a2a',
                            border: '#2a2a2a',      
                            borderLight: '#3a3a3a', 
                            textMuted: '#888888',   
                            text: '#e5e5e5',        
                        }
                    }
                }
            }
        }
    </script>

    <style>
        body { overscroll-behavior: none; }
        
        .bg-dots {
            background-color: #fafafa; 
            background-image: radial-gradient(#d4d4d8 1px, transparent 1px);
        }
        .dark .bg-dots {
            background-color: #0e0e0e; 
            background-image: radial-gradient(#222222 1px, transparent 1px); 
        }

        .tool-active {
            background-color: #e0f2fe;
            color: #0284c7;
            border-color: #bae6fd;
        }
        .dark .tool-active {
            background-color: #333333; 
            color: #ffffff; 
            border-color: #4a4a4a; 
        }

        .element-item { transition: transform 0.1s ease, box-shadow 0.2s ease; }
        .element-item:hover { box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1); }
        
        .image-dragging {
            opacity: 0.9;
            transform: scale(1.02);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5), 0 10px 10px -5px rgba(0, 0, 0, 0.3);
        }
        
        .delete-btn { display: none; }
        .image-container:hover .delete-btn, .element-container:hover .delete-btn { display: flex; }

        /* Transform Handles (Shown only on selection) */
        .element-container .handle { display: none; }
        .element-container.ring-1 .handle { display: flex; }

        /* Drop Indicators for Layers */
        .drag-over-top { box-shadow: inset 0 2px 0 0 #0ea5e9 !important; }
        .drag-over-bottom { box-shadow: inset 0 -2px 0 0 #0ea5e9 !important; }
        .dark .drag-over-top { box-shadow: inset 0 2px 0 0 #ffffff !important; }
        .dark .drag-over-bottom { box-shadow: inset 0 -2px 0 0 #ffffff !important; }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #d4d4d8; border-radius: 8px; }
        .dark ::-webkit-scrollbar-thumb { background: #333333; }
        .dark ::-webkit-scrollbar-thumb:hover { background: #555555; }
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        /* Hide Number Input Arrows */
        input[type=number]::-webkit-inner-spin-button, 
        input[type=number]::-webkit-outer-spin-button { 
            -webkit-appearance: none; 
            margin: 0; 
        }
        input[type=number] {
            -moz-appearance: textfield;
        }

        /* Brush Preview Cursor */
        #brush-cursor { mix-blend-mode: difference; }

        /* Custom Rotate Cursors */
        .cursor-rotate-nw { cursor: url('data:image/svg+xml;utf8,<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M16.5 15.5C16.5 11.0817 12.9183 7.5 8.5 7.5H6.5V10L2.5 6L6.5 2V4.5H8.5C14.5751 4.5 19.5 9.42487 19.5 15.5H16.5Z" fill="black" stroke="white" stroke-width="1"/></svg>') 12 12, auto; }
        .cursor-rotate-ne { cursor: url('data:image/svg+xml;utf8,<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M7.5 15.5C7.5 11.0817 11.0817 7.5 15.5 7.5H17.5V10L21.5 6L17.5 2V4.5H15.5C9.42487 4.5 4.5 9.42487 4.5 15.5H7.5Z" fill="black" stroke="white" stroke-width="1"/></svg>') 12 12, auto; }
        .cursor-rotate-sw { cursor: url('data:image/svg+xml;utf8,<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M16.5 8.5C16.5 12.9183 12.9183 16.5 8.5 16.5H6.5V14L2.5 18L6.5 22V19.5H8.5C14.5751 19.5 19.5 14.5751 19.5 8.5H16.5Z" fill="black" stroke="white" stroke-width="1"/></svg>') 12 12, auto; }
        .cursor-rotate-se { cursor: url('data:image/svg+xml;utf8,<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M7.5 8.5C7.5 12.9183 11.0817 16.5 15.5 16.5H17.5V14L21.5 18L17.5 22V19.5H15.5C9.42487 19.5 4.5 14.5751 4.5 8.5H7.5Z" fill="black" stroke="white" stroke-width="1"/></svg>') 12 12, auto; }

        /* Customizing Alwan Color Picker to look aesthetic */
        .alwan { border-radius: 12px; border: 1px solid rgba(128,128,128,0.2); box-shadow: 0 20px 40px -10px rgba(0,0,0,0.5); font-family: 'Inter', sans-serif; z-index: 999999 !important; }
    </style>
</head>
<body class="h-screen w-screen flex flex-col overflow-hidden text-slate-800 dark:text-app-text bg-white dark:bg-app-bg transition-colors duration-200 font-sans">

    <!-- Top Container: Header & Tabs -->
    <div class="flex flex-col z-[200] shadow-sm dark:shadow-none relative">
        <header class="bg-white dark:bg-app-panel border-b border-slate-200 dark:border-app-border pr-5 flex flex-col xl:flex-row justify-between transition-colors duration-200 z-20 relative pt-2">
            
            <!-- Left Side: File Menu & Tabs -->
            <div class="flex items-end gap-1 w-full xl:w-auto flex-1 min-w-0 pl-5 h-[68px]">
                <div class="flex items-center shrink-0 h-full">
                    <div class="relative flex items-center h-full">
                        <button onclick="toggleFileMenu()" class="flex items-center px-3 py-1.5 hover:bg-slate-100 dark:hover:bg-app-surfaceHover rounded-md transition-colors font-medium text-slate-700 dark:text-app-text">
                            <span class="text-sm tracking-wide">File</span>
                        </button>
                        <div id="file-menu" class="hidden absolute top-[calc(100%-10px)] left-0 mt-2 w-64 bg-white dark:bg-app-surface/90 dark:backdrop-blur-xl rounded-xl shadow-[0_10px_40px_rgba(0,0,0,0.5)] border border-slate-200 dark:border-[#333] py-2 z-[250]">
                            <button onclick="createNewProject(); toggleFileMenu();" class="w-full text-left px-5 py-2.5 hover:bg-brand-50 dark:hover:bg-brand-500/20 text-base flex items-center justify-between transition-colors">
                                <span>New Project</span><span class="text-sm text-slate-400 dark:text-app-textMuted">Ctrl+N</span>
                            </button>
                            <button onclick="openLocalFile(); toggleFileMenu();" class="w-full text-left px-5 py-2.5 hover:bg-brand-50 dark:hover:bg-brand-500/20 text-base flex items-center justify-between transition-colors">
                                <span>Open Local (.mb)</span>
                            </button>
                            <button onclick="saveProjectToLocal(); toggleFileMenu();" class="w-full text-left px-5 py-2.5 hover:bg-brand-50 dark:hover:bg-brand-500/20 text-base flex items-center justify-between transition-colors">
                                <span>Save</span><span class="text-sm text-slate-400 dark:text-app-textMuted">Ctrl+S</span>
                            </button>
                            <button onclick="saveProjectAsNew(); toggleFileMenu();" class="w-full text-left px-5 py-2.5 hover:bg-brand-50 dark:hover:bg-brand-500/20 text-base flex items-center justify-between transition-colors">
                                <span>Save As...</span>
                            </button>
                            <div class="h-px bg-slate-200 dark:bg-app-border my-1.5"></div>
                            <button onclick="clearCanvas(); toggleFileMenu();" class="w-full text-left px-5 py-2.5 hover:bg-red-50 dark:hover:bg-red-500/20 text-red-600 dark:text-red-400 text-base flex items-center justify-between transition-colors">
                                <span>Clear All Canvas</span>
                            </button>
                            <div class="h-px bg-slate-200 dark:bg-app-border my-1.5"></div>
                            <button onclick="openExportModal(); toggleFileMenu();" class="w-full text-left px-5 py-2.5 hover:bg-brand-50 dark:hover:bg-brand-500/20 text-base flex items-center justify-between transition-colors">
                                <span>Export to PDF...</span>
                            </button>
                        </div>
                    </div>
                    <div class="w-px h-5 bg-slate-300 dark:bg-[#333] mx-3"></div>
                </div>

                <!-- Tab Bar -->
                <div class="flex items-center gap-[1px] tabs-container overflow-x-auto overflow-y-hidden flex-1 h-full" id="tab-bar"></div>
            </div>

            <!-- Right Side: Zoom, Tools -->
            <div class="flex items-center gap-1.5 shrink-0 pl-5 xl:pl-0 h-[68px]">
                <!-- Zoom Controls -->
                <div class="flex items-center gap-1.5 bg-slate-100 dark:bg-app-surface p-1.5 rounded-lg border border-slate-200 dark:border-app-border transition-colors">
                    <button onclick="changeZoom(-0.1)" class="p-1.5 hover:bg-white dark:hover:bg-app-surfaceHover text-slate-600 dark:text-app-textMuted dark:hover:text-white rounded-md transition-colors" title="Zoom Out (-)">
                        <i class="ph ph-minus text-base"></i>
                    </button>
                    <span id="zoom-label" class="text-sm font-semibold w-12 text-center text-slate-600 dark:text-app-text cursor-pointer hover:text-brand-600 dark:hover:text-white" onclick="centerBoard()" title="Reset View (0)">100%</span>
                    <button onclick="changeZoom(0.1)" class="p-1.5 hover:bg-white dark:hover:bg-app-surfaceHover text-slate-600 dark:text-app-textMuted dark:hover:text-white rounded-md transition-colors" title="Zoom In (+)">
                        <i class="ph ph-plus text-base"></i>
                    </button>
                </div>

                <!-- Main Tools -->
                <div class="flex items-center bg-slate-100 dark:bg-app-surface p-1.5 rounded-lg border border-slate-200 dark:border-app-border transition-colors gap-0.5 ml-1">
                    <button onclick="setMode('move')" id="btn-move" class="tool-active flex items-center justify-center w-10 h-10 rounded-md transition-all" title="Select / Move (V)">
                        <i class="ph ph-arrows-out-cardinal text-xl"></i>
                    </button>
                    
                    <!-- Frame Tool -->
                    <button onclick="setMode('frame')" id="btn-frame" class="text-slate-600 dark:text-app-textMuted hover:bg-white dark:hover:bg-app-surfaceHover hover:text-slate-900 dark:hover:text-white flex items-center justify-center w-10 h-10 rounded-md transition-all" title="Add Canvas/Frame (F)">
                        <i class="ph ph-frame-corners text-xl"></i>
                    </button>

                    <div class="w-px bg-slate-300 dark:bg-app-border mx-1 my-2 h-6"></div>

                    <button onclick="setMode('text')" id="btn-text" class="text-slate-600 dark:text-app-textMuted hover:bg-white dark:hover:bg-app-surfaceHover hover:text-slate-900 dark:hover:text-white flex items-center justify-center w-10 h-10 rounded-md transition-all" title="Add Text (T)">
                        <i class="ph ph-text-t text-xl"></i>
                    </button>

                    <!-- SHAPE MENU -->
                    <div class="relative flex items-center group">
                        <button onclick="setMode('shape')" id="btn-shape" class="text-slate-600 dark:text-app-textMuted hover:bg-white dark:hover:bg-app-surfaceHover hover:text-slate-900 dark:hover:text-white flex items-center justify-center w-8 h-10 rounded-l-md transition-all" title="Add Shape (R)">
                            <i class="ph ph-square text-xl" id="current-shape-icon"></i>
                        </button>
                        <button onclick="toggleShapeMenu(event)" class="text-slate-500 hover:text-slate-800 dark:hover:text-white flex items-center justify-center w-3 h-10 rounded-r-md transition-all">
                            <i class="ph ph-caret-down text-[10px]"></i>
                        </button>
                        <div id="shape-menu" class="hidden absolute top-full left-1/2 -translate-x-1/2 mt-2 bg-white dark:bg-app-surface/95 dark:backdrop-blur-xl rounded-lg shadow-xl border border-slate-200 dark:border-[#333] p-1 flex gap-1 z-[250]">
                            <button onclick="selectShapeType('rect')" class="p-2 text-slate-700 dark:text-app-text hover:bg-slate-100 dark:hover:bg-[#333] rounded transition-colors" title="Rectangle"><i class="ph ph-square text-xl"></i></button>
                            <button onclick="selectShapeType('circle')" class="p-2 text-slate-700 dark:text-app-text hover:bg-slate-100 dark:hover:bg-[#333] rounded transition-colors" title="Circle"><i class="ph ph-circle text-xl"></i></button>
                            <button onclick="selectShapeType('triangle')" class="p-2 text-slate-700 dark:text-app-text hover:bg-slate-100 dark:hover:bg-[#333] rounded transition-colors" title="Triangle"><i class="ph ph-triangle text-xl"></i></button>
                            <button onclick="selectShapeType('star')" class="p-2 text-slate-700 dark:text-app-text hover:bg-slate-100 dark:hover:bg-[#333] rounded transition-colors" title="Star"><i class="ph ph-star text-xl"></i></button>
                        </div>
                    </div>

                    <button onclick="setMode('pentool')" id="btn-pentool" class="text-slate-600 dark:text-app-textMuted hover:bg-white dark:hover:bg-app-surfaceHover hover:text-slate-900 dark:hover:text-white flex items-center justify-center w-10 h-10 rounded-md transition-all" title="Vector Pen (B)">
                        <i class="ph ph-bezier-curve text-xl"></i>
                    </button>

                    <button onclick="setMode('connect')" id="btn-connect" class="text-slate-600 dark:text-app-textMuted hover:bg-white dark:hover:bg-app-surfaceHover hover:text-slate-900 dark:hover:text-white flex items-center justify-center w-10 h-10 rounded-md transition-all" title="Kabel (C)">
                        <i class="ph ph-link text-xl"></i>
                    </button>

                    <div class="w-px bg-slate-300 dark:bg-app-border mx-1 my-2 h-6"></div>
                    
                    <button onclick="setMode('pen')" id="btn-pen" class="text-slate-600 dark:text-app-textMuted hover:bg-white dark:hover:bg-app-surfaceHover hover:text-slate-900 dark:hover:text-white flex items-center justify-center w-10 h-10 rounded-md transition-all" title="Pulpen (P)">
                        <i class="ph ph-pen-nib text-xl"></i>
                    </button>
                    <button onclick="setMode('pencil')" id="btn-pencil" class="text-slate-600 dark:text-app-textMuted hover:bg-white dark:hover:bg-app-surfaceHover hover:text-slate-900 dark:hover:text-white flex items-center justify-center w-10 h-10 rounded-md transition-all" title="Pensil (N)">
                        <i class="ph ph-pencil-simple text-xl"></i>
                    </button>
                    <button onclick="setMode('highlighter')" id="btn-highlighter" class="text-slate-600 dark:text-app-textMuted hover:bg-white dark:hover:bg-app-surfaceHover hover:text-slate-900 dark:hover:text-white flex items-center justify-center w-10 h-10 rounded-md transition-all" title="Stabilo (H)">
                        <i class="ph ph-marker-circle text-xl"></i>
                    </button>
                    <button onclick="setMode('eraser')" id="btn-eraser" class="text-slate-600 dark:text-app-textMuted hover:bg-white dark:hover:bg-app-surfaceHover hover:text-slate-900 dark:hover:text-white flex items-center justify-center w-10 h-10 rounded-md transition-all" title="Penghapus Coretan (E)">
                        <i class="ph ph-eraser text-xl"></i>
                    </button>
                </div>

                <!-- Actions -->
                <div class="flex items-center gap-1.5 ml-1">
                    <button onclick="undo()" id="btn-undo" class="text-slate-400 dark:text-app-border p-2 w-10 h-10 flex items-center justify-center rounded-md transition-colors" title="Undo (Ctrl+Z)" disabled>
                        <i class="ph ph-arrow-u-up-left text-xl"></i>
                    </button>
                    <button onclick="redo()" id="btn-redo" class="text-slate-400 dark:text-app-border p-2 w-10 h-10 flex items-center justify-center rounded-md transition-colors" title="Redo (Ctrl+Y)" disabled>
                        <i class="ph ph-arrow-u-up-right text-xl"></i>
                    </button>
                    
                    <div class="w-px h-7 bg-slate-200 dark:bg-app-border my-auto mx-1"></div>

                    <button onclick="toggleSnap()" id="btn-snap" class="text-slate-500 dark:text-app-textMuted hover:bg-slate-200 dark:hover:bg-app-surface w-10 h-10 flex items-center justify-center rounded-md transition-colors" title="Snap to Grid (S)">
                        <i class="ph ph-magnet text-xl"></i>
                    </button>

                    <div class="w-px h-7 bg-slate-200 dark:bg-app-border my-auto mx-1"></div>

                    <button onclick="toggleDarkMode()" id="btn-dark" class="text-slate-500 dark:text-app-textMuted hover:bg-slate-200 dark:hover:bg-app-surface w-10 h-10 flex items-center justify-center rounded-md transition-colors" title="Toggle Dark Mode">
                        <i class="ph ph-moon text-xl" id="icon-dark"></i>
                    </button>

                    <input type="file" id="image-upload" class="hidden" accept="image/*" multiple onchange="handleImageUpload(event)">
                    <input type="file" id="mb-upload" class="hidden" accept=".mb" onchange="fallbackLoadLocal(event)">
                    <button onclick="document.getElementById('image-upload').click()" class="ml-1 bg-slate-800 dark:bg-white hover:bg-slate-700 dark:hover:bg-gray-200 text-white dark:text-black py-2.5 px-4 rounded-lg transition-colors flex items-center gap-2 text-sm font-semibold tracking-wide whitespace-nowrap shadow-md">
                        <i class="ph ph-image text-xl"></i>
                        <span>Import Image</span>
                    </button>
                </div>
            </div>
        </header>
        
        <!-- Text Format Floating Toolbar (Hidden by default) -->
        <div id="text-format-toolbar" class="hidden absolute top-20 left-1/2 -translate-x-1/2 bg-white dark:bg-app-surface/95 dark:backdrop-blur-xl border border-slate-200 dark:border-[#333] rounded-lg shadow-xl p-2 flex items-center gap-2 z-[250]">
            <select id="text-font" onchange="applyTextFormat('font', this.value)" onmousedown="event.preventDefault();" class="bg-slate-100 dark:bg-[#222] border-none rounded px-2 py-1 text-sm text-slate-800 dark:text-white focus:ring-1 focus:ring-brand-500 outline-none cursor-pointer">
                <option value='"Inter", sans-serif'>Inter</option>
                <option value='"Outfit", sans-serif'>Outfit</option>
                <option value='monospace'>Monospace</option>
                <option value='serif'>Serif</option>
            </select>
            
            <div class="flex items-center bg-slate-100 dark:bg-[#222] rounded px-2 py-1">
                <i class="ph ph-text-aa text-slate-500 dark:text-app-textMuted mr-1"></i>
                <input type="number" id="text-size" class="bg-transparent border-none w-12 text-sm text-slate-800 dark:text-white outline-none" title="Font Size (Drag horizontally to scrub)">
            </div>

            <div class="w-px h-5 bg-slate-300 dark:bg-app-border"></div>

            <button onmousedown="event.preventDefault();" onclick="applyTextFormat('bold')" class="p-1.5 hover:bg-slate-100 dark:hover:bg-[#333] rounded text-slate-700 dark:text-app-text transition-colors" title="Bold">
                <i class="ph ph-text-b text-lg pointer-events-none"></i>
            </button>
            <button onmousedown="event.preventDefault();" onclick="applyTextFormat('italic')" class="p-1.5 hover:bg-slate-100 dark:hover:bg-[#333] rounded text-slate-700 dark:text-app-text transition-colors" title="Italic">
                <i class="ph ph-text-italic text-lg pointer-events-none"></i>
            </button>
            
            <div class="w-px h-5 bg-slate-300 dark:bg-app-border"></div>

            <button onmousedown="event.preventDefault();" onclick="applyTextFormat('align', 'left')" class="p-1.5 hover:bg-slate-100 dark:hover:bg-[#333] rounded text-slate-700 dark:text-app-text transition-colors" title="Align Left">
                <i class="ph ph-text-align-left text-lg pointer-events-none"></i>
            </button>
            <button onmousedown="event.preventDefault();" onclick="applyTextFormat('align', 'center')" class="p-1.5 hover:bg-slate-100 dark:hover:bg-[#333] rounded text-slate-700 dark:text-app-text transition-colors" title="Align Center">
                <i class="ph ph-text-align-center text-lg pointer-events-none"></i>
            </button>
            <button onmousedown="event.preventDefault();" onclick="applyTextFormat('align', 'right')" class="p-1.5 hover:bg-slate-100 dark:hover:bg-[#333] rounded text-slate-700 dark:text-app-text transition-colors" title="Align Right">
                <i class="ph ph-text-align-right text-lg pointer-events-none"></i>
            </button>
        </div>
    </div>

    <!-- Main App Layout (Sidebar + Workspace + Properties) -->
    <div class="flex flex-1 overflow-hidden relative w-full h-full bg-white dark:bg-app-bg">
        
        <!-- Layers Panel (Left Sidebar) -->
        <aside id="layer-panel" class="hidden w-72 bg-white dark:bg-app-panel border-r border-slate-200 dark:border-app-border flex flex-col z-[200] shadow-[4px_0_15px_rgba(0,0,0,0.05)] dark:shadow-none h-full transition-all duration-300 shrink-0">
            <div class="p-4 border-b border-slate-200 dark:border-app-border flex justify-between items-center bg-slate-50 dark:bg-app-panel">
                <span class="font-semibold text-sm tracking-wide text-slate-800 dark:text-app-text flex items-center"><i class="ph ph-stack mr-2 text-lg"></i> Layers</span>
                <button onclick="toggleLayerPanel()" class="text-slate-400 dark:text-app-textMuted hover:text-slate-700 dark:hover:text-white transition-colors">
                    <i class="ph ph-x text-lg"></i>
                </button>
            </div>
            <div id="layers-list" class="flex-1 overflow-y-auto py-1"></div>
        </aside>

        <!-- Workspace (Center) -->
        <main id="workspace" class="flex-1 relative overflow-hidden bg-dots w-full cursor-default transition-colors duration-200 z-0">
            
            <!-- Rulers -->
            <div id="ruler-corner" class="absolute top-0 left-0 w-5 h-5 z-[15] bg-white dark:bg-[#161616] border-r border-b border-slate-200 dark:border-[#333] pointer-events-none"></div>
            <canvas id="ruler-h" class="absolute top-0 left-5 w-[calc(100%-20px)] h-5 z-[15] bg-white dark:bg-[#161616] border-b border-slate-200 dark:border-[#333] cursor-ns-resize"></canvas>
